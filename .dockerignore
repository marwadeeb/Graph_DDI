data/rag_index/checkpoints/
data/step5_gnn/

# ── Jupyter / editor artefacts ────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb
.DS_Store
.idea/
.vscode/

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.env
*.key

# ── Git history (not needed inside the image) ─────────────────────────────────
.git/
.gitignore
