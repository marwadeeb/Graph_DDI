# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Large binary / intermediate pipeline outputs ──────────────────────────────
