# ─────────────────────────────────────────────────────────────────────────────
# DDI Checker — Environment Variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# The app starts fine without GROQ_API_KEY — it just disables the AI chat
# feature at /chat. All drug-pair lookups and GNN predictions work without it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required for AI chat (/chat page) ────────────────────────────────────────
#
# GROQ_API_KEY — Groq Cloud API key
#
# The /chat endpoint uses Groq's LLM API for named-entity recognition (NER)
# and natural-language interaction summaries. Without this key the /chat page
# will return a 503 error; all other pages and the /api/check endpoint are
# unaffected.
#
# How to get one (free):
#   1. Go to https://console.groq.com
#   2. Sign up / log in
#   3. Navigate to API Keys → Create API Key
#   4. Paste the key below (starts with "gsk_")
#
GROQ_API_KEY=gsk_your_key_here

# ── Optional — already set in Dockerfile / app defaults ──────────────────────
#
# These are hardcoded in the Dockerfile and in app.py defaults. You only need
# to set them here if you are running WITHOUT Docker and want to override them.
#
# Suppress TensorFlow import warnings from HuggingFace transformers
# TRANSFORMERS_NO_TF=1
#
# Silence TensorFlow C++ log spam
# TF_CPP_MIN_LOG_LEVEL=3
#
# Flask environment ("development" gives you the interactive debugger locally)
# FLASK_ENV=development
